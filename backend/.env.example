# ===== 应用基础 =====
APP_NAME=FindJobAgent
DEBUG=True

# ===== MySQL 数据库 =====
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DB=job_agent
# 也可直接指定完整 URL（可选，会自动从 MYSQL_* 拼接）
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/job_agent?charset=utf8mb4

# ===== JWT 认证 =====
# 生产环境务必替换 SECRET_KEY，可用 python -c "import secrets; print(secrets.token_urlsafe(32))" 生成
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== 登录注册 / 邮箱验证码 =====
AUTH_VERIFICATION_EXPIRE_SECONDS=300
AUTH_VERIFICATION_RESEND_SECONDS=60
AUTH_VERIFICATION_CODE_LENGTH=6
AUTH_EMAIL_SEND_ENABLED=True
AUTH_DEBUG_RETURN_CODE=False
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_FROM=
EMAIL_PASSWORD=

# ===== 简历上传 =====
# 上传文件的存储目录（相对于 backend 目录）
RESUME_UPLOAD_DIR=uploads/resumes

# ===== AI 模型（OpenAI 兼容接口）=====
# DeepSeek 示例：
# AI_BASE_URL=https://api.deepseek.com/v1
# AI_MODEL=deepseek-chat
# AI_API_KEY=your-api-key
AI_BASE_URL=
AI_MODEL=
AI_API_KEY=
AI_ANALYSIS_ENABLED=True
AI_TIMEOUT_SECONDS=60
AI_TEMPERATURE=0.2

# ===== Agent 3 简历优化 =====
OPTIMIZATION_OUTPUT_DIR=outputs/optimized_resumes
OPTIMIZATION_MAX_WORKERS=4

# ===== CORS =====
# 前端开发服务器地址，多个用逗号分隔
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
