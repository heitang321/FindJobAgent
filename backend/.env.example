# ===== 应用基础 =====
APP_NAME=FindJobAgent
DEBUG=True

# ===== 数据库 =====
# 格式: postgresql+asyncpg://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/findjobagent

# ===== JWT 认证 =====
# 生产环境务必替换 SECRET_KEY，可用 python -c "import secrets; print(secrets.token_urlsafe(32))" 生成
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== 简历上传 =====
# 上传文件的存储目录（相对于 backend 目录）
RESUME_UPLOAD_DIR=uploads/resumes

# ===== AI 模型（OpenAI 兼容接口）=====
# DeepSeek 示例：
# AI_BASE_URL=https://api.deepseek.com/v1
# AI_MODEL=deepseek-chat
# AI_API_KEY=your-api-key
AI_BASE_URL=
AI_MODEL=
AI_API_KEY=
AI_ANALYSIS_ENABLED=True
AI_TIMEOUT_SECONDS=60
AI_TEMPERATURE=0.2

# ===== CORS =====
# 前端开发服务器地址，多个用逗号分隔
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
